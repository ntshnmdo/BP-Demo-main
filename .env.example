# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/battery_passport"

# JWT
JWT_SECRET="battery-passport-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
BACKEND_PORT=3001
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# File Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# Blockchain (Mock for MVP — change to "adichain" for production)
BLOCKCHAIN_PROVIDER="mock"

# Node Environment
NODE_ENV="development"
