# Battery Passport Frontend Environment Variables
# Copy this file to .env.local and fill in the actual values

# Blockchain Configuration
# The RPC URL is the Ethereum/Web3 node endpoint
# Example: https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_RPC_URL=https://your-ethereum-rpc-endpoint

# The contract address of the Battery Passport smart contract
# Example: 0x1234567890123456789012345678901234567890
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddress

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
